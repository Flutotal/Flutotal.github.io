---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL;
---

<header>
	<nav class="site-nav" data-menu-open="false">
		<h2><a href={base}>{SITE_TITLE}</a></h2>
		<button class="menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false">
			<span aria-hidden="true">☰</span>
		</button>
		<div class="internal-links" id="site-menu">
			<HeaderLink href={base}>Home</HeaderLink>
			<HeaderLink href={`${base}blog/`}>Blog</HeaderLink>
			<HeaderLink href={`${base}categories/`}>Categorias</HeaderLink>
			<HeaderLink href={`${base}archive/`}>Arquivo</HeaderLink>
			<HeaderLink href={`${base}about/`}>About</HeaderLink>
		</div>
	</nav>
</header>
<script>
	(() => {
		const nav = document.querySelector('nav.site-nav');
		const btn = document.querySelector('nav.site-nav .menu-toggle');
		if (!(nav instanceof HTMLElement) || !(btn instanceof HTMLButtonElement)) return;

		const setOpen = (open) => {
			nav.dataset.menuOpen = open ? 'true' : 'false';
			btn.setAttribute('aria-expanded', open ? 'true' : 'false');
			btn.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');
		};

		btn.addEventListener('click', () => setOpen(nav.dataset.menuOpen !== 'true'));
		window.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') setOpen(false);
		});
	})();
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		position: sticky;
		top: 0;
		z-index: 50;
		background:
			linear-gradient(90deg, rgba(255, 43, 214, 0.14), transparent 45%, rgba(0, 255, 119, 0.12)),
			rgba(var(--bg-rgb), 0.82);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid rgba(var(--border-rgb), 1);
		box-shadow: 0 10px 35px rgba(0, 0, 0, 0.35);
	}
	h2 {
		margin: 0;
		font-size: 0.95em;
		letter-spacing: 0.02em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		max-width: var(--container);
		margin: 0 auto;
		position: relative;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgba(var(--text-rgb), 0.92);
		border-bottom: 2px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: rgba(34, 211, 238, 0.85);
		text-shadow: 0 0 14px rgba(34, 211, 238, 0.25);
	}
	nav a:hover {
		text-shadow: 0 0 14px rgba(255, 43, 214, 0.18);
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
	}

	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 0.75rem;
		border-radius: 10px;
		border: 1px solid rgba(var(--border-rgb), 1);
		background: rgba(var(--surface-rgb), 0.25);
		color: rgba(var(--text-rgb), 0.92);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
		cursor: pointer;
	}

	@media (max-width: 720px) {
		.menu-toggle {
			display: inline-flex;
		}

		.internal-links {
			display: none;
			position: absolute;
			top: calc(100% + 0.35rem);
			left: 0;
			right: 0;
			flex-direction: column;
			gap: 0;
			padding: 0.25rem;
			border-radius: 14px;
			border: 1px solid rgba(var(--border-rgb), 1);
			background: rgba(var(--surface-rgb), 0.92);
			box-shadow: var(--glow);
		}

		nav[data-menu-open='true'] .internal-links {
			display: flex;
		}

		.internal-links :global(a) {
			padding: 0.9rem 0.85rem;
			border-bottom: 1px solid rgba(var(--border-rgb), 0.45);
		}

		.internal-links :global(a:last-child) {
			border-bottom: 0;
		}
	}
</style>
