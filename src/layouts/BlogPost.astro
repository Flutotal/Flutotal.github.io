---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	heroImageUrl,
	game,
	platform,
	youtubeId,
	youtubeUrl,
	images,
	tags,
} = Astro.props;

const coverUrl = heroImageUrl || undefined;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} imageUrl={coverUrl} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero {
				width: 100%;
			}
			.hero img {
				display: block;
				margin: 0 auto;
				border-radius: 16px;
				box-shadow: var(--shadow-md);
			}
			.prose {
				width: 920px;
				max-width: calc(100% - 2.5em);
				margin: auto;
				padding: 1.25em 0 0;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1.25em;
				padding: 0.75em 0 0.25em;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 0.75rem;
				margin: 0.75rem 0 0;
			}
			.pill {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.35rem 0.6rem;
				border: 1px solid rgba(var(--border-rgb), 1);
				border-radius: 999px;
				background: rgba(var(--surface-rgb), 0.7);
				backdrop-filter: blur(10px);
				color: rgba(var(--text-rgb), 0.92);
				font-size: 0.9rem;
				line-height: 1;
				white-space: nowrap;
			}
			.gallery {
				margin: 1.5rem 0 0;
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.75rem;
			}
			.gallery img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 14px;
				border: 1px solid rgba(var(--border-rgb), 1);
				box-shadow: var(--shadow-sm);
			}
			@media (max-width: 900px) {
				.gallery {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}
			@media (max-width: 560px) {
				.gallery {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero">
					{(youtubeId || youtubeUrl) && (
						<YouTubeEmbed id={youtubeId} url={youtubeUrl} title={title} />
					)}
					{!(youtubeId || youtubeUrl) && heroImage && <Image width={1200} height={675} src={heroImage} alt="" />}
					{!(youtubeId || youtubeUrl) && heroImageUrl && <img src={heroImageUrl} alt="" loading="lazy" decoding="async" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{(game || platform || (tags && tags.length)) && (
							<div class="meta" aria-label="Post metadata">
								{game && <span class="pill">🎮 {game}</span>}
								{platform && <span class="pill">🕹️ {platform}</span>}
								{tags?.map((t) => <span class="pill">#{t}</span>)}
							</div>
						)}
						<hr />
					</div>
					<slot />

					{images?.length ? (
						<section aria-label="Gameplay screenshots">
							<h2>Imagens</h2>
							<div class="gallery">
								{images.map((src) => (
									<a href={src} target="_blank" rel="noreferrer">
										<img src={src} alt="" loading="lazy" decoding="async" />
									</a>
								))}
							</div>
						</section>
					) : null}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
