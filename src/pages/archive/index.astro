---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL;

const categoriesSet = new Set();
for (const post of posts) {
	const c = post.data.category || post.data.platform || 'Outros';
	categoriesSet.add(c);
}
const categories = [...categoriesSet].sort((a, b) => a.localeCompare(b));

const groups = new Map();
for (const post of posts) {
	const d = new Date(post.data.pubDate);
	const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
	if (!groups.has(key)) groups.set(key, []);
	groups.get(key).push(post);
}
const keys = [...groups.keys()].sort((a, b) => b.localeCompare(a));

const label = (key) => {
	const [y, m] = key.split('-').map(Number);
	return new Date(y, m - 1, 1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Arquivo`} description={SITE_DESCRIPTION} />
		<style>
			.controls {
				display: grid;
				grid-template-columns: 1fr 260px;
				gap: 0.75rem;
				margin: 0 0 1.25rem;
			}
			.input,
			.select {
				width: 100%;
				padding: 0.8rem 0.9rem;
				border-radius: 14px;
				border: 1px solid rgba(var(--border-rgb), 1);
				background: rgba(var(--surface-rgb), 0.72);
				color: rgba(var(--text-rgb), 0.92);
				box-shadow: var(--shadow-sm);
				outline: none;
			}
			.input::placeholder {
				color: rgba(var(--muted-rgb), 0.9);
			}
			.note {
				margin: -0.5rem 0 1.25rem;
				color: rgba(var(--muted-rgb), 0.95);
				font-size: 0.95rem;
			}
			.group {
				margin: 0 0 1.25rem;
				border: 1px solid rgba(var(--border-rgb), 1);
				border-radius: 18px;
				background: rgba(var(--surface-rgb), 0.72);
				backdrop-filter: blur(12px);
				box-shadow: var(--shadow-sm);
				padding: 1rem;
			}
			.group h2 {
				margin: 0 0 0.75rem;
				font-size: 1.1rem;
				text-transform: capitalize;
			}
			.list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.4rem;
			}
			.list a {
				display: block;
				padding: 0.35rem 0.4rem;
				border-radius: 10px;
				text-decoration: none;
				color: rgba(var(--text-rgb), 0.92);
			}
			.list a:hover {
				background: rgba(var(--surface-rgb), 1);
			}
			.row {
				display: flex;
				justify-content: space-between;
				gap: 0.75rem;
				align-items: baseline;
			}
			.when {
				flex: 0 0 auto;
				color: rgba(var(--muted-rgb), 0.95);
				font-variant-numeric: tabular-nums;
				font-size: 0.9rem;
			}
			.what {
				min-width: 0;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.empty {
				display: none;
				border: 1px dashed rgba(var(--border-rgb), 1);
				border-radius: 18px;
				padding: 1rem;
				color: rgba(var(--muted-rgb), 0.95);
				background: rgba(var(--surface-rgb), 0.55);
			}
			@media (max-width: 720px) {
				.controls {
					grid-template-columns: 1fr;
				}
			}
			@media (max-width: 560px) {
				.row {
					flex-direction: column;
					align-items: flex-start;
					gap: 0.15rem;
				}
				.what {
					white-space: normal;
					overflow: visible;
					text-overflow: clip;
				}
				.when {
					font-size: 0.85rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Arquivo</h1>
			<div class="controls" role="search">
				<input
					id="q"
					class="input"
					type="search"
					placeholder="Buscar por título, jogo ou plataforma…"
					autocomplete="off"
				/>
				<select id="cat" class="select" aria-label="Filtrar por categoria">
					<option value="">Todas as categorias</option>
					{categories.map((c) => (
						<option value={c}>{c}</option>
					))}
				</select>
			</div>
			<p class="note">Dica: você também pode clicar nos meses/anos na home para pular direto no grupo.</p>
			<div id="empty" class="empty">Nenhum post encontrado com esse filtro.</div>
			{keys.map((k) => (
				<section class="group" id={k} aria-label={label(k)} data-group>
					<h2>{label(k)}</h2>
					<ul class="list">
						{groups.get(k).map((post) => (
							<li
								data-item
								data-category={post.data.category || post.data.platform || 'Outros'}
								data-title={`${post.data.title} ${(post.data.game || '')} ${(post.data.platform || '')}`.toLowerCase()}
							>
								<a href={`${base}blog/${post.id}/`}>
									<span class="row">
										<span class="what">{post.data.title}</span>
										<span class="when"><FormattedDate date={post.data.pubDate} /></span>
									</span>
								</a>
							</li>
						))}
					</ul>
				</section>
			))}
		</main>
		<Footer />
		<script>
			const q = document.getElementById('q');
			const cat = document.getElementById('cat');
			const empty = document.getElementById('empty');
			const groups = Array.from(document.querySelectorAll('[data-group]'));

			function applyFilters() {
				const query = (q.value || '').trim().toLowerCase();
				const category = cat.value || '';
				let anyVisible = false;

				for (const g of groups) {
					const items = Array.from(g.querySelectorAll('[data-item]'));
					let groupHasAny = false;
					for (const it of items) {
						const itCat = it.getAttribute('data-category') || '';
						const itTitle = it.getAttribute('data-title') || '';
						const okCat = !category || itCat === category;
						const okQ = !query || itTitle.includes(query);
						const show = okCat && okQ;
						it.style.display = show ? '' : 'none';
						if (show) groupHasAny = true;
					}
					g.style.display = groupHasAny ? '' : 'none';
					if (groupHasAny) anyVisible = true;
				}

				empty.style.display = anyVisible ? 'none' : 'block';
			}

			q.addEventListener('input', applyFilters);
			cat.addEventListener('change', applyFilters);
			applyFilters();
		</script>
	</body>
</html>

