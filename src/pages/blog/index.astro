---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1120px;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1.25rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.card {
				border: 1px solid rgba(var(--border-rgb), 1);
				border-radius: 18px;
				background: rgba(var(--surface-rgb), 0.75);
				backdrop-filter: blur(12px);
				box-shadow: var(--shadow-sm);
				overflow: hidden;
			}
			.card a {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.thumb {
				aspect-ratio: 16 / 9;
				background: rgba(var(--surface-rgb), 1);
				overflow: hidden;
			}
			.thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.body {
				padding: 0.9rem 1rem 1rem;
			}
			.title {
				margin: 0;
				line-height: 1.15;
			}
			.desc {
				margin: 0.55rem 0 0;
				color: rgba(var(--text-rgb), 0.72);
				font-size: 0.95rem;
				line-height: 1.45;
			}
			.date {
				margin: 0.55rem 0 0;
				color: rgba(var(--text-rgb), 0.62);
				font-size: 0.9rem;
			}
			.card:hover {
				transform: translateY(-1px);
				box-shadow: var(--shadow-md);
				border-color: rgba(var(--border-rgb), 0.9);
			}
			.card * {
				transition: 180ms ease;
			}
			@media (max-width: 1000px) {
				.grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}
			@media (max-width: 620px) {
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul class="grid">
					{
						posts.map((post) => (
							<li class="card">
								<a href={`${base}blog/${post.id}/`}>
									<div class="thumb">
										{post.data.heroImage ? (
											<img src={post.data.heroImage.src} alt={`Capa do post ${post.data.title}`} loading="lazy" decoding="async" />
										) : post.data.heroImageUrl ? (
											<img src={post.data.heroImageUrl} alt={`Capa do post ${post.data.title}`} loading="lazy" decoding="async" />
										) : null}
									</div>
									<div class="body">
										<h3 class="title">{post.data.title}</h3>
										{post.data.description ? <p class="desc">{post.data.description}</p> : null}
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
