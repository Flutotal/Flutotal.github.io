---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import CompactPostList from '../../components/CompactPostList.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const set = new Set();
	for (const post of posts) {
		const c = post.data.category || post.data.platform || 'Outros';
		set.add(c);
	}
	return [...set].map((category) => ({
		params: { category },
		props: { category },
	}));
}

const { category } = Astro.props;
const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const posts = allPosts.filter((p) => (p.data.category || p.data.platform || 'Outros') === category);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — ${category}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<p style="margin: 0 0 0.75rem"><a href={`${base}categories/`}>← Todas as categorias</a></p>
			<h1 style="margin-top: 0">{category}</h1>
			<CompactPostList posts={posts} />
		</main>
		<Footer />
	</body>
</html>

